# ========================================
# CONFIGURAÇÃO DO SISTEMA WHATSAPP SENDER
# ========================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores com suas credenciais
# 3. NUNCA compartilhe o arquivo .env com suas chaves reais
#

# ========================================
# GOOGLE SHEETS (Opcional)
# ========================================
# Se você usa Google Sheets para armazenar mensagens
# Obtenha o ID da URL: https://docs.google.com/spreadsheets/d/[DOCUMENT_ID]/edit
GOOGLE_SHEETS_DOCUMENT_ID=seu_document_id_aqui
GOOGLE_SHEETS_TESTES_2026_SHEET_ID=seu_sheet_id_aqui

# ========================================
# EVOLUTION API - WHATSAPP (Obrigatório)
# ========================================
# URL da sua instância Evolution API
# Exemplo: https://evolution.seudominio.com.br
EVOLUTION_API_URL=https://sua-evolution-api.com.br

# Chave de API da Evolution
# Obtenha em: Painel Evolution > Configurações > API Key
EVOLUTION_API_KEY=sua_api_key_aqui

# Nome da sua instância WhatsApp
# Obtenha em: Painel Evolution > Instâncias
EVOLUTION_INSTANCE=NOME_DA_SUA_INSTANCIA

# ========================================
# CONFIGURAÇÃO DA APLICAÇÃO
# ========================================
# Nível de log: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Ambiente: development, production
ENVIRONMENT=development

# Host do servidor webhook (0.0.0.0 = todas as interfaces)
WEBHOOK_HOST=0.0.0.0

# Porta do servidor webhook
WEBHOOK_PORT=8000

# Caminho do webhook (não alterar)
WEBHOOK_PATH=/webhook/:test_cases_auto

# ========================================
# WEBHOOK DE RECEPÇÃO (Obrigatório)
# ========================================
# URL completa do webhook que receberá as respostas do WhatsApp
# Este é o mesmo webhook usado para envio
# 
# Exemplo: https://webhook.etechats.com.br/webhook/TESTE01
WEBHOOK_RECEPTION_URL=https://webhook.seudominio.com.br/webhook/SUA_INSTANCIA

# ========================================
# GITHUB (Opcional)
# ========================================
# Token para commits e push automáticos
# Gere em: https://github.com/settings/tokens
# Permissões necessárias: repo (todas)
GITHUB_TOKEN=seu_github_token_aqui

# ========================================
# NOTAS IMPORTANTES
# ========================================
# 
# EVOLUTION API:
# - Certifique-se de que sua instância está conectada
# - Teste a conexão antes de enviar mensagens em massa
# - Respeite os limites de envio do WhatsApp
#
# SEGURANÇA:
# - NUNCA commite o arquivo .env no Git
# - Use .env.example como template
# - Mantenha suas chaves em segredo
#
# SUPORTE:
# - Documentação: README.md
# - Guia do usuário: README_USUARIO.md
#
